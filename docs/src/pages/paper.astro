---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';

// At build time cwd is the docs/ directory
const paperMd = readFileSync(join(process.cwd(), '../paper/knowledge-gap.md'), 'utf-8');
// marked parses repo-committed markdown -- not user input
const html = await marked(paperMd);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>The Knowledge Gap — Open Knowledge Protocol</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        background: #fff;
        color: #111;
        margin: 0;
      }
      .paper-page {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 1.1rem;
        line-height: 1.8;
        max-width: 72ch;
        margin: 0 auto;
        padding: 4rem 2rem;
        text-align: justify;
        hyphens: auto;
      }
      h1 {
        font-size: 1.8rem;
        text-align: center;
        font-weight: 600;
        line-height: 1.3;
        margin-bottom: 0.25rem;
      }
      h2 {
        font-size: 1.3rem;
        font-weight: 600;
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
        border-bottom: 1px solid #e8e8e0;
        padding-bottom: 0.25rem;
      }
      h3 {
        font-size: 1.1rem;
        font-style: italic;
        font-weight: 400;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
      }
      p {
        margin: 0.75rem 0;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
        font-size: 0.95rem;
        font-family: system-ui, sans-serif;
      }
      th,
      td {
        border: 1px solid #ccc;
        padding: 0.4rem 0.75rem;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #f5f5f0;
        font-weight: 600;
      }
      code {
        font-family: 'Courier New', Courier, monospace;
        font-size: 0.88em;
        background: #f5f5f0;
        padding: 0.1em 0.35em;
        border-radius: 3px;
      }
      pre {
        background: #f5f5f0;
        padding: 1rem;
        overflow-x: auto;
        border-radius: 4px;
        font-size: 0.9em;
      }
      pre code {
        background: none;
        padding: 0;
      }
      hr {
        border: none;
        border-top: 1px solid #e8e8e0;
        margin: 2.5rem 0;
      }
      blockquote {
        border-left: 3px solid #ccc;
        margin: 1rem 0;
        padding-left: 1rem;
        color: #555;
        font-style: italic;
      }
      ul,
      ol {
        padding-left: 1.5rem;
      }
      li {
        margin: 0.3rem 0;
      }
      a {
        color: #c88800;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      strong {
        font-weight: 600;
      }
      .pdf-btn {
        text-align: right;
        margin-bottom: 2rem;
        font-family: system-ui, sans-serif;
      }
      .pdf-btn button {
        background: #ffb000;
        border: none;
        color: #000;
        padding: 0.5rem 1.25rem;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.01em;
      }
      .pdf-btn button:hover {
        background: #e6a000;
      }
      .back-link {
        font-family: system-ui, sans-serif;
        font-size: 0.85rem;
        margin-bottom: 1.5rem;
        display: block;
      }
      @media print {
        .pdf-btn,
        .back-link {
          display: none;
        }
        body {
          font-size: 11pt;
        }
        .paper-page {
          max-width: 100%;
          padding: 0;
        }
      }
      @media (max-width: 600px) {
        .paper-page {
          padding: 2rem 1rem;
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <div class="paper-page">
      <a href="/" class="back-link">← Open Knowledge Protocol</a>
      <div class="pdf-btn">
        <button onclick="window.print()">Save as PDF</button>
      </div>
      <Fragment set:html={html} />
    </div>
  </body>
</html>
