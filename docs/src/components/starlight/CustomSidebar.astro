---
import type { Props } from '@astrojs/starlight/props';
const { sidebar } = Astro.props;
---

<nav class="okp-sidebar" aria-label="Main navigation" data-testid="custom-sidebar">
  {sidebar.map((entry) => (
    entry.type === 'link' ? (
      <div class="okp-sidebar__top-link">
        <a
          href={entry.href}
          class:list={['okp-sidebar__item', 'okp-sidebar__item--top', { 'okp-sidebar__item--active': entry.isCurrent }]}
          aria-current={entry.isCurrent ? 'page' : undefined}
          data-testid={`sidebar-item-${entry.label.toLowerCase().replace(/\s+/g, '-')}`}
        >
          {entry.label}
        </a>
      </div>
    ) : (
      <div class="okp-sidebar__group">
        {entry.label && (
          <div class="okp-sidebar__group-header">
            <span class="okp-sidebar__group-title">{entry.label}</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="10"
              height="10"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="okp-sidebar__chevron"
              aria-hidden="true"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
        )}
        <ul class="okp-sidebar__items" role="list">
          {entry.entries?.map((item) => (
            item.type === 'link' ? (
              <li>
                <a
                  href={item.href}
                  class:list={['okp-sidebar__item', { 'okp-sidebar__item--active': item.isCurrent }]}
                  aria-current={item.isCurrent ? 'page' : undefined}
                  data-testid={`sidebar-item-${item.label.toLowerCase().replace(/\s+/g, '-')}`}
                >
                  {item.label}
                </a>
              </li>
            ) : item.type === 'group' ? (
              <li>
                <div class="okp-sidebar__nested-group">
                  {item.label && (
                    <span class="okp-sidebar__nested-title">{item.label}</span>
                  )}
                  <ul class="okp-sidebar__items" role="list">
                    {item.entries?.map((nested) => (
                      nested.type === 'link' && (
                        <li>
                          <a
                            href={nested.href}
                            class:list={['okp-sidebar__item', { 'okp-sidebar__item--active': nested.isCurrent }]}
                            aria-current={nested.isCurrent ? 'page' : undefined}
                            data-testid={`sidebar-item-${nested.label.toLowerCase().replace(/\s+/g, '-')}`}
                          >
                            {nested.label}
                          </a>
                        </li>
                      )
                    ))}
                  </ul>
                </div>
              </li>
            ) : null
          ))}
        </ul>
      </div>
    )
  ))}
</nav>

<style>
  .okp-sidebar {
    width: 260px;
    flex-shrink: 0;
    border-right: 1px solid #e8e3de;
    background: #ffffff;
    padding: 24px 16px;
    overflow-y: auto;
    height: 100%;
  }

  .okp-sidebar__group {
    margin-bottom: 1.25rem;
  }

  .okp-sidebar__group-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0.5rem;
    margin-bottom: 0.25rem;
    cursor: default;
  }

  .okp-sidebar__group-title {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8580;
    line-height: 1;
  }

  .okp-sidebar__chevron {
    color: #8a8580;
    flex-shrink: 0;
  }

  .okp-sidebar__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .okp-sidebar__item {
    display: block;
    font-size: 0.85rem;
    padding: 0.375rem 0.5rem;
    border-radius: 6px;
    color: #5a5550;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
    line-height: 1.4;
  }

  .okp-sidebar__item:hover {
    color: #1c1e21;
    background: #f5f0eb;
  }

  .okp-sidebar__item--active {
    color: #e46b39;
    font-weight: 600;
    background: #fef3ee;
  }

  .okp-sidebar__item--active:hover {
    color: #e46b39;
    background: #fef3ee;
  }

  .okp-sidebar__nested-group {
    margin-top: 0.125rem;
  }

  .okp-sidebar__nested-title {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8580;
    padding: 0.375rem 0.5rem 0.25rem;
    line-height: 1;
  }

  /* Top-level flat link items — no chevron */
  .okp-sidebar__top-link {
    margin-bottom: 0.25rem;
  }

  .okp-sidebar__item--top {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8580;
    padding: 0.375rem 0.5rem;
    display: block;
    border-radius: 6px;
    text-decoration: none;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .okp-sidebar__item--top:hover {
    color: #1c1e21;
    background: #f5f0eb;
  }

  .okp-sidebar__item--top.okp-sidebar__item--active {
    color: #e46b39;
    font-weight: 700;
    background: #fef3ee;
  }
</style>
