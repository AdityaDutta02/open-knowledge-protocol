---
import type { Props } from '@astrojs/starlight/props';
const { toc } = Astro.props;
---

{toc && toc.items && toc.items.length > 0 && (
  <aside class="okp-toc" aria-label="Table of contents" data-testid="custom-toc">
    <h4 class="okp-toc__label">On this page</h4>
    <nav>
      <ul class="okp-toc__list" role="list">
        {toc.items.map((item) => (
          <li>
            <a
              href={`#${item.slug}`}
              class:list={[
                'okp-toc__item',
                { 'okp-toc__item--nested': item.depth > 2 }
              ]}
              data-heading-id={item.slug}
              data-testid={`toc-item-${item.slug}`}
            >
              {item.text}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>
)}

<style>
  .okp-toc {
    width: 200px;
    flex-shrink: 0;
    padding: 32px 0;
    overflow-y: auto;
    height: 100%;
  }

  .okp-toc__label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8580;
    margin-bottom: 0.75rem;
    padding-left: 12px;
    line-height: 1;
  }

  .okp-toc__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .okp-toc__item {
    display: block;
    font-size: 0.8rem;
    padding: 0.25rem 0 0.25rem 12px;
    border-left: 2px solid transparent;
    color: #8a8580;
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
    line-height: 1.4;
  }

  .okp-toc__item:hover {
    color: #5a5550;
    border-left-color: #d8d3ce;
  }

  .okp-toc__item--nested {
    padding-left: 20px;
    font-size: 0.75rem;
  }

  .okp-toc__item--active {
    color: #e46b39;
    border-left-color: #e46b39;
    font-weight: 500;
  }
</style>

<script>
  function initTOCObserver() {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('[data-heading-id]');
    if (!tocLinks.length) return;

    const headingIds = Array.from(tocLinks).map((link) => link.dataset.headingId ?? '');
    const headingElements = headingIds
      .map((id) => document.getElementById(id))
      .filter((el): el is HTMLElement => el !== null);

    if (!headingElements.length) return;

    function setActive(id: string) {
      tocLinks.forEach((link) => {
        const isActive = link.dataset.headingId === id;
        link.classList.toggle('okp-toc__item--active', isActive);
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            setActive(entry.target.id);
            break;
          }
        }
      },
      {
        rootMargin: '-10% 0% -80% 0%',
        threshold: 0,
      }
    );

    headingElements.forEach((el) => observer.observe(el));

    // Set initial active state based on first visible heading
    if (headingElements[0]) {
      setActive(headingElements[0].id);
    }

    return () => observer.disconnect();
  }

  document.addEventListener('DOMContentLoaded', initTOCObserver);
  // Also run for View Transitions
  document.addEventListener('astro:page-load', initTOCObserver);
</script>
